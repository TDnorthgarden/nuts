{
  "metadata": {
    "name": "manual-verify-container",
    "attempt": 1
  },
  "image": {
    "image": "swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/busybox:1.36.0"
  },
  "command": [
    "/bin/sh",
    "-c",
    "trap : TERM INT; while true; do sleep 3600; done"
  ],
  "log_path": "manual-verify-container.log",
  "linux": {
    "security_context": {
      "privileged": false
    }
  }
}
